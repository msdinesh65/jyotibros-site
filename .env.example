# NextAuth — generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-long-random-string"
NEXTAUTH_URL="http://localhost:3002"

# PostgreSQL — required for COD, Razorpay checkout, and customer accounts.
#
# Option A — Docker (this repo includes docker-compose.yml):
#   docker compose up -d
#   npx prisma migrate deploy
#
# Option B — hosted free tier: Neon (https://neon.tech), Supabase, Railway — paste their connection string.
#
DATABASE_URL="postgresql://jyoti:jyoti_dev@localhost:5432/jyotibros"

# Razorpay (https://dashboard.razorpay.com/app/keys)
# Use Test keys for development; switch to Live keys only in production.
# Key ID must be the same value in both places below (public + server).

RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Exposed to the browser — only the Key ID, never the secret.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
