{
  "name": "jyoti-bros-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "dev:clean": "rm -rf .next && next dev -p 3002",
    "dev:restart": "bash -c 'pid=$(lsof -ti:3002 2>/dev/null); [ -n \"$pid\" ] && kill -9 $pid; rm -rf .next && exec next dev -p 3002'",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:local": "docker compose up -d"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "next": "14.2.5",
    "next-auth": "^4.24.11",
    "razorpay": "^2.9.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.38",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5"
  }
}
